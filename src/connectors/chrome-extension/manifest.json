{
  "manifest_version": 3,
  "name": "real-browser-mcp connector",
  "version": "0.1.0",
  "description": "Publishes safe real-browser tab snapshots to the local real-browser-mcp bridge.",
  "permissions": [
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
