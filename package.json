{
  "name": "real-browser-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server for interacting with a real logged-in browser session",
  "license": "MIT",
  "bin": {
    "real-browser-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node dist/cli.js package-extension",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "test": "tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.321",
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
